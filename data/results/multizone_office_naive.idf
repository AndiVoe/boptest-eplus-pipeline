    1.8235459961295193, 0, 2.4000000000000004,
    1.8235459961295193, 0, 0.6000000000000001,
    16.411913965165674, 0, 0.6000000000000001,
    16.411913965165674, 0, 2.4000000000000004;

! --- Internal gains ---

People,
    Cor_People,  !- Name
    Cor,         !- Zone or ZoneList or Space or SpaceList Name
    Office Occupancy,        !- Number of People Schedule Name
    People/Area,             !- Number of People Calculation Method
    ,                        !- Number of People
    0.05,  !- People per Zone Floor Area {person/m2}
    ,                        !- Zone Floor Area per Person {m2/person}
    0.3,                     !- Fraction Radiant
    autocalculate,           !- Sensible Heat Fraction
    Activity Level Schedule; !- Activity Level Schedule Name

Lights,
    Cor_Lights,  !- Name
    Cor,         !- Zone or ZoneList or Space or SpaceList Name
    Office Occupancy,        !- Schedule Name
    Watts/Area,              !- Design Level Calculation Method
    ,                        !- Lighting Level {W}
    10,  !- Watts per Floor Area {W/m2}
    ,                        !- Watts per Person {W/person}
    0,                       !- Return Air Fraction
    0.72,                    !- Fraction Radiant
    0.18,                    !- Fraction Visible
    1;                       !- Fraction Replaceable

ElectricEquipment,
    Cor_Equipment,  !- Name
    Cor,         !- Zone or ZoneList or Space or SpaceList Name
    Office Occupancy,        !- Schedule Name
    Watts/Area,              !- Design Level Calculation Method
    ,                        !- Design Level {W}
    12,  !- Watts per Floor Area {W/m2}
    ,                        !- Watts per Person {W/person}
    0,                       !- Fraction Latent
    0.5,                     !- Fraction Radiant
    0;                       !- Fraction Lost

ZoneInfiltration:DesignFlowRate,
    Cor_Infiltration,  !- Name
    Cor,         !- Zone or ZoneList or Space or SpaceList Name
    Always On,               !- Schedule Name
    AirChanges/Hour,         !- Design Flow Rate Calculation Method
    ,                        !- Design Flow Rate {m3/s}
    ,                        !- Flow per Zone Floor Area {m3/s-m2}
    ,                        !- Flow per Exterior Surface Area {m3/s-m2}
    0.5;  !- Air Changes per Hour {1/hr}

! --- HVAC: IdealLoadsAirSystem ---

ZoneControl:Thermostat,
    Cor Thermostat,  !- Name
    Cor,         !- Zone or ZoneList Name
    HVACTemplate-Always 4,   !- Control Type Schedule Name
    ThermostatSetpoint:DualSetpoint,  !- Control Object Type
    Cor Dual SP; !- Control Name

ThermostatSetpoint:DualSetpoint,
    Cor Dual SP, !- Name
    Heating Setpoint Schedule,  !- Heating Setpoint Temperature Schedule Name
    Cooling Setpoint Schedule;  !- Cooling Setpoint Temperature Schedule Name

ZoneHVAC:EquipmentConnections,
    Cor,         !- Zone Name
    Cor Equipment,  !- Zone Conditioning Equipment List Name
    Cor Supply Inlet,  !- Zone Air Inlet Node or NodeList Name
    ,                        !- Zone Air Exhaust Node or NodeList Name
    Cor Air Node,  !- Zone Air Node Name
    Cor Return;  !- Zone Return Air Node Name

ZoneHVAC:EquipmentList,
    Cor Equipment,  !- Name
    SequentialLoad,          !- Load Distribution Scheme
    ZoneHVAC:IdealLoadsAirSystem,  !- Zone Equipment Object Type
    Cor Ideal Loads,  !- Zone Equipment Name
    1,                       !- Zone Equipment Cooling Sequence
    1,                       !- Zone Equipment Heating or No-Load Sequence
    ,                        !- Zone Equipment Sequential Cooling Fraction
    ;                        !- Zone Equipment Sequential Heating Fraction

ZoneHVAC:IdealLoadsAirSystem,
    Cor Ideal Loads,  !- Name
    Always On,               !- Availability Schedule Name
    Cor Supply Inlet,  !- Zone Supply Air Node Name
    ,                        !- Zone Exhaust Air Node Name
    ,                        !- System Inlet Air Node Name
    50,                      !- Maximum Heating Supply Air Temperature [C]
    13,                      !- Minimum Cooling Supply Air Temperature [C]
    0.0156,                  !- Maximum Heating Supply Air Humidity Ratio
    0.0077,                  !- Minimum Cooling Supply Air Humidity Ratio
    LimitCapacity,           !- Heating Limit
    ,                        !- Maximum Heating Air Flow Rate {m3/s}
    3000,  !- Maximum Sensible Heating Capacity {W}
    LimitCapacity,           !- Cooling Limit
    ,                        !- Maximum Cooling Air Flow Rate {m3/s}
    3000,  !- Maximum Total Cooling Capacity {W}
    ,                        !- Heating Availability Schedule Name
    ,                        !- Cooling Availability Schedule Name
    ConstantSensibleHeatRatio,  !- Dehumidification Control Type
    0.7,                     !- Cooling Sensible Heat Ratio
    None,                    !- Humidification Control Type
    ,                        !- Design Specification Outdoor Air Object Name
    ,                        !- Outdoor Air Inlet Node Name
    None,                    !- Demand Controlled Ventilation Type
    NoEconomizer,            !- Outdoor Air Economizer Type
    None,                    !- Heat Recovery Type
    0.7,                     !- Sensible Heat Recovery Effectiveness
    0.65;                    !- Latent Heat Recovery Effectiveness


