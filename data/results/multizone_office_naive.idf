    0, 18.23545996129519, 0,
    0, 0, 0,
    0, 0, 3.0;

FenestrationSurface:Detailed,
    Cor_Window_South,  !- Name
    Window,                  !- Surface Type
    Simple_Window_Const,  !- Construction Name
    Cor_Wall_South,  !- Building Surface Name
    ,                        !- Outside Boundary Condition Object
    autocalculate,           !- View Factor to Ground
    ,                        !- Frame and Divider Name
